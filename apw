#!/usr/bin/env bash

set -euo pipefail

APW_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
BOOTSTRAP_SCRIPT="$APW_ROOT/scripts/bootstrap.sh"
VALIDATE_SCRIPT="$APW_ROOT/scripts/validate.sh"
INIT_STATE_SCRIPT="$APW_ROOT/scripts/init-project-state.sh"
UPGRADE_PROJECT_SCRIPT="$APW_ROOT/scripts/upgrade-project.sh"
APW_COMMAND_NAME="${APW_COMMAND_NAME:-apw}"

usage() {
    cat <<EOF
Usage:
  $APW_COMMAND_NAME new <project-name> [--profile base|minimal|advanced] [--stack value] [--target dir] [--force] [--skip-validate] [--init-state]
  $APW_COMMAND_NAME upgrade-project <name-or-path> [--workspace dir] [--profile auto|minimal|base|advanced] [--stack value] [--dry-run] [--force-managed] [--validate]
  $APW_COMMAND_NAME context [path]
  $APW_COMMAND_NAME first-run [path]
  $APW_COMMAND_NAME list-projects [--workspace dir]
  $APW_COMMAND_NAME switch framework [--open]
  $APW_COMMAND_NAME switch project <name-or-path> [--workspace dir] [--open]
  $APW_COMMAND_NAME switch parent [--workspace dir] [--open]
  $APW_COMMAND_NAME help

Examples:
  $APW_COMMAND_NAME new ProjectA
  $APW_COMMAND_NAME new ProjectB --profile advanced --stack base
  $APW_COMMAND_NAME new ProjectC --target /path/to/MyWork
  $APW_COMMAND_NAME new ProjectD --target /path/to/MyWork --init-state
  $APW_COMMAND_NAME upgrade-project ProjectA --dry-run
  $APW_COMMAND_NAME upgrade-project ProjectB --workspace /path/to/MyWork --force-managed --validate
  $APW_COMMAND_NAME upgrade-project /path/to/MyWork/ProjectC
  $APW_COMMAND_NAME context
  $APW_COMMAND_NAME context /path/to/MyWork/ProjectA
  $APW_COMMAND_NAME first-run
  $APW_COMMAND_NAME first-run /path/to/MyWork/ProjectA
  $APW_COMMAND_NAME list-projects
  $APW_COMMAND_NAME switch framework
  $APW_COMMAND_NAME switch project ProjectA
  $APW_COMMAND_NAME switch project /path/to/MyWork/ProjectA
  $APW_COMMAND_NAME switch parent

What it does:
  - creates a new project directory under the chosen target location
  - runs the canonical bootstrap flow underneath
  - runs validation by default
  - can optionally launch guided project-state initialization
  - safely upgrades an existing downstream project with APW-managed improvements
  - explains whether a path is APW root, a downstream project root, or a workspace/general folder
  - prints the beginner-friendly first-run checklist for a downstream project
  - lists known downstream projects in the workspace
  - resolves a switch target clearly without silently changing your shell

Notes:
  - Canonical invocation is: apw ...
  - Install the workspace launcher from APW root with: ./scripts/install-workspace-launcher.sh
  - Path-based invocation still works for maintenance and recovery, but apw is the primary entrypoint.
  - Automatic workspace inference is supported from APW root, the workspace parent, and downstream project roots.
  - From an unrelated folder, pass --workspace or --target explicitly instead of expecting APW to guess.
  - This is a workspace-friendly wrapper around scripts/bootstrap.sh and scripts/validate.sh.
  - APW: Create Project uses this same destination resolver.
  - Default new-project destination is workspace-aware:
    - from APW root, create the project in the parent workspace beside apw
    - from the workspace parent, create the project in the current folder
    - from a downstream project, create the project as a sibling in the same workspace parent
    - use --target to override the parent location explicitly
  - The bootstrap contract still lives in PROJECT_BOOTSTRAP.md.
  - upgrade-project protects project-owned .gsd memory and code by default.
  - Switch helpers are explicit and visible. They print where to go next; they do not silently mutate your shell context.
EOF
}

require_script() {
    local script_path="$1"

    if [[ ! -f "$script_path" ]]; then
        echo "Error: Missing required APW script: $script_path"
        exit 1
    fi
}

ensure_safe_project_name() {
    local project_name="$1"

    if [[ -z "$project_name" ]]; then
        echo "Error: Project name is required."
        usage
        exit 1
    fi

    if [[ "$project_name" == "." || "$project_name" == ".." || "$project_name" == */* ]]; then
        echo "Error: Project name must be a simple directory name, not a path."
        exit 1
    fi
}

directory_is_empty() {
    local dir_path="$1"

    if find "$dir_path" -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null | grep -q .; then
        return 1
    fi

    return 0
}

default_workspace_parent() {
    dirname "$APW_ROOT"
}

APW_INVOCATION_PATH=""
APW_INVOCATION_CONTEXT=""
APW_INVOCATION_REASON=""
APW_INVOCATION_WORKSPACE_PARENT=""
APW_INVOCATION_PROJECT_ROOT=""

NEW_PROJECT_TARGET_PARENT=""
NEW_PROJECT_TARGET_CONTEXT=""
NEW_PROJECT_TARGET_REASON=""

resolve_existing_path() {
    local input_path="${1:-.}"

    if [[ ! -e "$input_path" ]]; then
        echo "Error: Path does not exist: $input_path"
        exit 1
    fi

    if [[ -d "$input_path" ]]; then
        (cd "$input_path" && pwd -P)
    else
        (cd "$(dirname "$input_path")" && printf '%s/%s\n' "$(pwd -P)" "$(basename "$input_path")")
    fi
}

resolve_invocation_context() {
    local input_path="${1:-}"
    local default_parent=""
    local downstream_root=""

    if [[ -z "$input_path" ]]; then
        input_path="$(pwd -P)"
    fi

    default_parent="$(default_workspace_parent)"

    APW_INVOCATION_PATH="$input_path"
    APW_INVOCATION_CONTEXT=""
    APW_INVOCATION_REASON=""
    APW_INVOCATION_WORKSPACE_PARENT=""
    APW_INVOCATION_PROJECT_ROOT=""

    if [[ "$input_path" == "$APW_ROOT" ]]; then
        APW_INVOCATION_CONTEXT="framework-root"
        APW_INVOCATION_REASON="Current directory is the APW framework root."
        APW_INVOCATION_WORKSPACE_PARENT="$default_parent"
        return 0
    fi

    if [[ "$input_path" == "$default_parent" ]]; then
        APW_INVOCATION_CONTEXT="workspace-parent"
        APW_INVOCATION_REASON="Current directory is the workspace parent that contains apw and downstream sibling repos."
        APW_INVOCATION_WORKSPACE_PARENT="$default_parent"
        return 0
    fi

    if is_downstream_project_root "$input_path"; then
        APW_INVOCATION_CONTEXT="downstream-project-root"
        APW_INVOCATION_REASON="Current directory is a downstream APW project root."
        APW_INVOCATION_WORKSPACE_PARENT="$(dirname "$input_path")"
        APW_INVOCATION_PROJECT_ROOT="$input_path"
        return 0
    fi

    if [[ "$input_path" == "$APW_ROOT"/* ]]; then
        APW_INVOCATION_CONTEXT="unsupported"
        APW_INVOCATION_REASON="Current directory is inside APW root but not at the APW framework root itself."
        APW_INVOCATION_WORKSPACE_PARENT="$default_parent"
        return 0
    fi

    if downstream_root="$(find_downstream_root "$input_path" 2>/dev/null)"; then
        APW_INVOCATION_CONTEXT="unsupported"
        APW_INVOCATION_REASON="Current directory is inside a downstream APW project but not at that project's root: $downstream_root"
        APW_INVOCATION_WORKSPACE_PARENT="$(dirname "$downstream_root")"
        APW_INVOCATION_PROJECT_ROOT="$downstream_root"
        return 0
    fi

    APW_INVOCATION_CONTEXT="unsupported"
    APW_INVOCATION_REASON="Current directory is not the APW framework root, the workspace parent, or a downstream APW project root."
}

print_supported_invocation_contexts() {
    echo "Supported invocation contexts:"
    echo "- APW framework root: $APW_ROOT"
    echo "- Workspace parent: $(default_workspace_parent)"
    echo "- Downstream APW project root: <workspace>/<project>"
}

fail_unsupported_invocation_context() {
    local command_name="$1"
    local explicit_hint="${2:-}"
    local current_path="${3:-}"

    if [[ -z "$current_path" ]]; then
        current_path="$(pwd -P)"
    fi

    resolve_invocation_context "$current_path"

    echo "Error: $command_name cannot infer APW workspace routing from this location: $APW_INVOCATION_PATH" >&2
    echo "Detected invocation context: unsupported" >&2
    echo "Reason: $APW_INVOCATION_REASON" >&2
    echo >&2
    print_supported_invocation_contexts >&2
    echo >&2
    echo "Next steps:" >&2
    echo "- cd $(printf '%q' "$APW_ROOT") and re-run the command" >&2
    echo "- cd $(printf '%q' "$(default_workspace_parent)") and re-run the command" >&2
    if [[ -n "$explicit_hint" ]]; then
        echo "- or pass $explicit_hint explicitly" >&2
    fi
    exit 1
}

resolve_workspace_parent() {
    local input_path="${1:-}"
    local command_name="${2:-$APW_COMMAND_NAME}"
    local resolved_path=""
    local current_path=""

    if [[ -z "$input_path" ]]; then
        current_path="$(pwd -P)"
        resolve_invocation_context "$current_path"

        case "$APW_INVOCATION_CONTEXT" in
            framework-root|workspace-parent)
                resolved_path="$APW_INVOCATION_WORKSPACE_PARENT"
                ;;
            downstream-project-root)
                resolved_path="$APW_INVOCATION_WORKSPACE_PARENT"
                ;;
            unsupported)
                fail_unsupported_invocation_context "$command_name" "--workspace /path/to/workspace" "$current_path"
                ;;
            *)
                echo "Error: Unknown invocation context: $APW_INVOCATION_CONTEXT"
                exit 1
                ;;
        esac
    else
        resolved_path="$(resolve_existing_path "$input_path")"
    fi

    if [[ ! -d "$resolved_path" ]]; then
        echo "Error: Workspace parent must be a directory: $resolved_path"
        exit 1
    fi

    printf '%s\n' "$resolved_path"
}

resolve_new_project_target_parent() {
    local explicit_target="${1:-}"
    local current_path="${2:-}"

    NEW_PROJECT_TARGET_PARENT=""
    NEW_PROJECT_TARGET_CONTEXT=""
    NEW_PROJECT_TARGET_REASON=""

    if [[ -n "$explicit_target" ]]; then
        NEW_PROJECT_TARGET_PARENT="$explicit_target"
        NEW_PROJECT_TARGET_CONTEXT="explicit-target"
        NEW_PROJECT_TARGET_REASON="Using the parent directory supplied with --target."
        return 0
    fi

    if [[ -z "$current_path" ]]; then
        current_path="$(pwd -P)"
    fi

    resolve_invocation_context "$current_path"

    case "$APW_INVOCATION_CONTEXT" in
        framework-root)
            NEW_PROJECT_TARGET_PARENT="$APW_INVOCATION_WORKSPACE_PARENT"
            NEW_PROJECT_TARGET_CONTEXT="framework-root"
            NEW_PROJECT_TARGET_REASON="Current context is APW root, so new downstream projects default to the parent workspace as siblings of apw."
            ;;
        workspace-parent)
            NEW_PROJECT_TARGET_PARENT="$APW_INVOCATION_PATH"
            NEW_PROJECT_TARGET_CONTEXT="workspace-parent"
            NEW_PROJECT_TARGET_REASON="Current context is the workspace parent, so the new downstream project defaults to a child of the current folder."
            ;;
        downstream-project-root)
            NEW_PROJECT_TARGET_PARENT="$APW_INVOCATION_WORKSPACE_PARENT"
            NEW_PROJECT_TARGET_CONTEXT="downstream-project-root"
            NEW_PROJECT_TARGET_REASON="Current context is a downstream project root, so new downstream projects default to the same workspace parent as sibling repos."
            ;;
        unsupported)
            fail_unsupported_invocation_context "$APW_COMMAND_NAME new" "--target /path/to/parent" "$current_path"
            ;;
        *)
            echo "Error: Unknown invocation context: $APW_INVOCATION_CONTEXT"
            exit 1
            ;;
    esac
}

is_downstream_project_root() {
    local candidate="$1"

    [[ -d "$candidate" ]] || return 1

    if [[ -f "$candidate/AGENTS.md" && -d "$candidate/.gsd" && -d "$candidate/.agent" && -f "$candidate/PROJECT_RULES.md" ]]; then
        [[ "$candidate" != "$APW_ROOT" ]] || return 1
        return 0
    fi

    return 1
}

find_downstream_root() {
    local start_path="$1"
    local current="$start_path"

    if [[ -f "$start_path" ]]; then
        current="$(dirname "$start_path")"
    fi

    while [[ "$current" != "/" ]]; do
        if is_downstream_project_root "$current"; then
            printf '%s\n' "$current"
            return 0
        fi

        current="$(dirname "$current")"
    done

    return 1
}

list_workspace_projects() {
    local workspace_parent="$1"
    local child=""
    local project_roots=()

    for child in "$workspace_parent"/*; do
        [[ -d "$child" ]] || continue

        if is_downstream_project_root "$child"; then
            project_roots+=("$child")
        fi
    done

    if [[ "${#project_roots[@]}" -eq 0 ]]; then
        return 0
    fi

    printf '%s\n' "${project_roots[@]}" | sort
}

format_cd_command() {
    printf 'cd %q\n' "$1"
}

format_shell_command() {
    local rendered=""
    local arg=""

    for arg in "$@"; do
        if [[ -n "$rendered" ]]; then
            rendered+=" "
        fi
        rendered+="$(printf '%q' "$arg")"
    done

    printf '%s\n' "$rendered"
}

LAUNCHER_LABEL=""
LAUNCHER_KIND=""
LAUNCHER_PRIMARY_CMD=""
LAUNCHER_APP_NAME=""

detect_open_launcher() {
    LAUNCHER_LABEL=""
    LAUNCHER_KIND=""
    LAUNCHER_PRIMARY_CMD=""
    LAUNCHER_APP_NAME=""

    if command -v antigravity >/dev/null 2>&1; then
        LAUNCHER_LABEL="Antigravity CLI"
        LAUNCHER_KIND="cli"
        LAUNCHER_PRIMARY_CMD="antigravity"
        return 0
    fi

    if command -v cursor >/dev/null 2>&1; then
        LAUNCHER_LABEL="Cursor CLI"
        LAUNCHER_KIND="cli"
        LAUNCHER_PRIMARY_CMD="cursor"
        return 0
    fi

    if [[ "${OSTYPE:-}" == darwin* ]] && command -v open >/dev/null 2>&1; then
        if open -Ra "Antigravity" >/dev/null 2>&1; then
            LAUNCHER_LABEL="Antigravity app"
            LAUNCHER_KIND="macos-app"
            LAUNCHER_APP_NAME="Antigravity"
            return 0
        fi

        if open -Ra "Cursor" >/dev/null 2>&1; then
            LAUNCHER_LABEL="Cursor app"
            LAUNCHER_KIND="macos-app"
            LAUNCHER_APP_NAME="Cursor"
            return 0
        fi
    fi

    if command -v code >/dev/null 2>&1; then
        LAUNCHER_LABEL="VS Code CLI"
        LAUNCHER_KIND="cli"
        LAUNCHER_PRIMARY_CMD="code"
        return 0
    fi

    if [[ "${OSTYPE:-}" == darwin* ]] && command -v open >/dev/null 2>&1; then
        if open -Ra "Visual Studio Code" >/dev/null 2>&1; then
            LAUNCHER_LABEL="Visual Studio Code app"
            LAUNCHER_KIND="macos-app"
            LAUNCHER_APP_NAME="Visual Studio Code"
            return 0
        fi
    fi

    return 1
}

run_open_launcher() {
    local target_path="$1"

    case "$LAUNCHER_KIND" in
        cli)
            "$LAUNCHER_PRIMARY_CMD" "$target_path"
            ;;
        macos-app)
            open -a "$LAUNCHER_APP_NAME" "$target_path"
            ;;
        *)
            return 1
            ;;
    esac
}

format_open_launcher_command() {
    local target_path="$1"

    case "$LAUNCHER_KIND" in
        cli)
            format_shell_command "$LAUNCHER_PRIMARY_CMD" "$target_path"
            ;;
        macos-app)
            format_shell_command open -a "$LAUNCHER_APP_NAME" "$target_path"
            ;;
        *)
            return 1
            ;;
    esac
}

print_switch_next_steps() {
    local target_path="$1"
    local target_kind="$2"
    local open_requested="$3"
    local open_command=""

    echo "Next:"
    echo "- APW does not silently change your shell or IDE."
    printf '%s\n' "- Run: $(format_cd_command "$target_path")"
    echo "- Exact folder for Antigravity or another IDE: $target_path"

    if detect_open_launcher; then
        open_command="$(format_open_launcher_command "$target_path")"
        if [[ "$open_requested" -eq 1 ]]; then
            printf '%s\n' "- Open request: APW will try $LAUNCHER_LABEL with: $open_command"
        else
            printf '%s\n' "- Antigravity-friendly open command: $open_command"
        fi
    else
        echo "- Manual Antigravity step: open that exact folder path in Antigravity."
    fi

    case "$target_kind" in
        framework)
            echo "- Maintain APW docs, templates, scripts, and workflows there."
            ;;
        project)
            echo "- Open AGENTS.md there and do normal project work from that repo root."
            ;;
        parent)
            echo "- Use that folder to choose a project, launch helpers, or switch again into the repo you actually want."
            ;;
    esac
}

maybe_open_target() {
    local target_path="$1"
    local open_requested="$2"

    if [[ "$open_requested" -eq 0 ]]; then
        return 0
    fi

    echo

    if detect_open_launcher; then
        echo "Optional open requested: launching the selected folder with $LAUNCHER_LABEL."
        if ! run_open_launcher "$target_path" >/dev/null 2>&1; then
            echo "$LAUNCHER_LABEL did not open cleanly."
            printf '%s\n' "Run manually: $(format_open_launcher_command "$target_path")"
            return 1
        fi
        echo "Open request sent via: $LAUNCHER_LABEL."
    else
        echo "Optional open requested, but no Antigravity-compatible launcher was detected."
        echo "Open the folder manually in Antigravity or another IDE with this exact path:"
        echo "  $target_path"
    fi
}

print_switch_summary() {
    local target_kind="$1"
    local target_path="$2"
    local open_requested="$3"

    echo "APW switch helper"
    echo "Resolved path: $target_path"
    echo

    case "$target_kind" in
        framework)
            echo "Switch target: APW framework root"
            echo "Use this for:"
            echo "- APW docs, templates, scripts, and workflow maintenance"
            echo "- bootstrap, validation, and helper operations against target repos"
            echo "Avoid doing here:"
            echo "- normal downstream project implementation"
            ;;
        project)
            echo "Switch target: downstream project root"
            echo "Use this for:"
            echo "- normal day-to-day project work"
            echo "- AGENTS.md, slash workflows, code changes, and project-local .gsd state"
            echo "Avoid doing here:"
            echo "- editing APW framework source unless you intentionally mean to maintain APW"
            ;;
        parent)
            echo "Switch target: workspace parent folder"
            echo "Use this for:"
            echo "- project discovery, launching helpers, and choosing where new repos should live"
            echo "- moving between APW root and downstream projects"
            echo "Avoid doing here:"
            echo "- day-to-day project workflows"
            ;;
        *)
            echo "Error: Unsupported switch target kind: $target_kind"
            exit 1
            ;;
    esac

    echo
    print_switch_next_steps "$target_path" "$target_kind" "$open_requested"
}

resolve_project_switch_target() {
    local selector="$1"
    local workspace_parent="$2"
    local resolved_path=""
    local downstream_root=""
    local child=""
    local project_roots=()
    local matched_project=""

    if [[ -e "$selector" ]]; then
        resolved_path="$(resolve_existing_path "$selector")"

        if downstream_root="$(find_downstream_root "$resolved_path")"; then
            printf '%s\n' "$downstream_root"
            return 0
        fi

        echo "Error: Path is not inside a downstream APW project: $resolved_path"
        exit 1
    fi

    while IFS= read -r child; do
        [[ -n "$child" ]] || continue
        project_roots+=("$child")
    done < <(list_workspace_projects "$workspace_parent")

    for child in "${project_roots[@]}"; do
        if [[ "$(basename "$child")" == "$selector" ]]; then
            matched_project="$child"
            break
        fi
    done

    if [[ -n "$matched_project" ]]; then
        printf '%s\n' "$matched_project"
        return 0
    fi

    echo "Error: Could not find downstream project '$selector' under workspace parent: $workspace_parent"

    if [[ "${#project_roots[@]}" -gt 0 ]]; then
        echo "Known downstream projects:"
        printf '%s\n' "${project_roots[@]}" | sed 's|.*/|- |'
    else
        echo "No downstream projects were detected under that workspace parent."
    fi

    exit 1
}

file_matches_bootstrap_template() {
    local target_file="$1"
    local file_name="$2"
    local candidate=""

    for candidate in \
        "$APW_ROOT/templates/base/.gsd/$file_name" \
        "$APW_ROOT/templates/minimal/.gsd/$file_name" \
        "$APW_ROOT/templates/advanced/.gsd/$file_name"
    do
        if [[ -f "$candidate" ]] && cmp -s "$target_file" "$candidate"; then
            return 0
        fi
    done

    return 1
}

downstream_needs_guided_init() {
    local project_root="$1"
    local file_name=""

    for file_name in SPEC.md STACK.md TODO.md STATE.md ROADMAP.md; do
        if [[ ! -f "$project_root/.gsd/$file_name" ]]; then
            return 0
        fi

        if file_matches_bootstrap_template "$project_root/.gsd/$file_name" "$file_name"; then
            return 0
        fi
    done

    return 1
}

run_context() {
    local input_path="${1:-.}"
    local resolved_path=""

    resolved_path="$(resolve_existing_path "$input_path")"
    resolve_invocation_context "$resolved_path"

    echo "APW context check"
    echo "Path: $resolved_path"
    echo "Invocation context: $APW_INVOCATION_CONTEXT"
    echo "Reason: $APW_INVOCATION_REASON"
    echo

    if [[ "$APW_INVOCATION_CONTEXT" == "framework-root" ]]; then
        echo "Context: APW root"
        echo "Role: framework source, templates, bootstrap/validation engine, and APW maintenance"
        echo "Typical actions:"
        echo "- maintain APW docs, templates, scripts, and workflows"
        echo "- run apw wrapper commands"
        echo "- bootstrap, validate, or initialize downstream repos by target path"
        echo "Avoid doing here:"
        echo "- day-to-day product implementation for a downstream project"
        echo "- treating the APW repo itself as the place where project slash workflows normally belong"
        echo
        echo "Helpful next commands:"
        echo "- $APW_COMMAND_NAME list-projects"
        echo "- $APW_COMMAND_NAME switch project <name>"
        echo "- $APW_COMMAND_NAME switch parent"
        return 0
    fi

    if [[ "$APW_INVOCATION_CONTEXT" == "downstream-project-root" ]]; then
        echo "Context: downstream project root"
        echo "Role: normal day-to-day project work happens here"
        echo "Typical actions:"
        echo "- open your IDE here"
        echo "- start from AGENTS.md here"
        echo "- run project slash workflows here"
        echo "- edit code, tests, docs, and project-local .gsd/.agent materials here"
        echo "Avoid doing here:"
        echo "- editing the APW framework itself unless you intentionally mean to work on APW"
        echo "- assuming this repo is the source of APW templates or validators"
        echo
        echo "Helpful next commands:"
        echo "- $APW_COMMAND_NAME first-run \"$resolved_path\""
        echo "- $APW_COMMAND_NAME switch project \"$resolved_path\""
        echo "- $APW_COMMAND_NAME switch framework"
        return 0
    fi

    if [[ "$APW_INVOCATION_CONTEXT" == "workspace-parent" ]]; then
        echo "Context: workspace parent folder"
        echo "Role: organizer and launch point"
        echo "Typical actions:"
        echo "- create a new project with: $APW_COMMAND_NAME new MyProject --profile base --stack base"
        echo "- list known downstream projects"
        echo "- switch into APW root or a downstream project explicitly"
        echo "Avoid doing here:"
        echo "- running day-to-day project slash workflows here"
        echo "- treating this folder as the canonical home of project state"
        echo
        echo "Helpful next commands:"
        echo "- $APW_COMMAND_NAME list-projects"
        echo "- $APW_COMMAND_NAME switch framework"
        echo "- $APW_COMMAND_NAME switch project <name>"
        return 0
    fi

    echo "Context: unsupported location"
    echo "Role: not currently identified as APW root, the workspace parent, or a downstream APW project root"
    echo "Typical actions:"
    echo "- move to APW root, the workspace parent, or a downstream project root before using workspace-inferred APW commands"
    echo "- or pass an explicit workspace with: $APW_COMMAND_NAME list-projects --workspace /path/to/MyWork"
    echo "- or pass an explicit parent with: $APW_COMMAND_NAME new MyProject --profile base --stack base --target /path/to/MyWork"
    echo "Avoid doing here:"
    echo "- assuming project slash workflows belong here"
    echo "- assuming this folder has APW state just because APW is installed somewhere else"
    echo
    print_supported_invocation_contexts
}

run_first_run() {
    local input_path="${1:-.}"
    local resolved_path=""
    local downstream_root=""
    local project_display=""

    resolved_path="$(resolve_existing_path "$input_path")"

    echo "APW first-run guide"
    echo "Path: $resolved_path"
    echo

    if [[ "$resolved_path" == "$APW_ROOT" || "$resolved_path" == "$APW_ROOT"/* ]]; then
        echo "You are in APW root, which is the framework repo."
        echo
        echo "For the first-run IDE experience of a real project:"
        echo "1. Open the downstream project root, not APW root."
        echo "2. If you do not have a project yet, create one with:"
        echo "   $APW_COMMAND_NAME new MyProject --profile base --stack base"
        echo "3. If you want help finding the right repo, run:"
        echo "   $APW_COMMAND_NAME list-projects"
        echo "4. Then re-run:"
        echo "   $APW_COMMAND_NAME first-run /path/to/MyProject"
        return 0
    fi

    if ! downstream_root="$(find_downstream_root "$resolved_path")"; then
        echo "This path is not inside a downstream APW project."
        echo
        echo "If you need a new project:"
        echo "1. Run: $APW_COMMAND_NAME new MyProject --profile base --stack base"
        echo "2. Open that downstream project in your IDE"
        echo "3. Then run: $APW_COMMAND_NAME first-run /path/to/MyProject"
        echo
        echo "If the project already exists but you are in the wrong folder:"
        echo "1. Run: $APW_COMMAND_NAME list-projects"
        echo "2. Run: $APW_COMMAND_NAME switch project <name>"
        return 0
    fi

    project_display="$downstream_root"

    echo "Downstream project root: $project_display"
    echo
    echo "First-run checklist:"
    echo "1. Confirm you are working from the downstream project root."
    echo "2. Open AGENTS.md first."

    if downstream_needs_guided_init "$downstream_root"; then
        echo "3. The core .gsd drafts still look uninitialized. Run:"
        echo "   $INIT_STATE_SCRIPT --target \"$downstream_root\""
    else
        echo "3. The core .gsd drafts already exist. Review .gsd/STATE.md and .gsd/TODO.md first."
    fi

    echo "4. Choose the first workflow that matches your situation:"
    echo "   - use /brainstorm if the idea or first step is still unclear"
    echo "   - use /create if the first feature is already clear"
    echo "   - use /orchestrate if the work is large or crosses multiple areas"
    echo "   - use /status if you are returning later or feel unsure where to begin"
    echo "5. Use the orchestrator when official summary files such as STATE.md, ROADMAP.md, TODO.md, or DECISIONS.md need synchronized updates."
    echo
    echo "Read only if needed:"
    echo "- docs/FIRST_RUN_IN_IDE.md"
    echo "- docs/WORKFLOW_SELECTION_GUIDE.md"
    echo "- docs/COMMAND_INVOCATION_GUIDE.md"
    echo "- docs/WHERE_DO_I_WORK.md"
}

run_list_projects() {
    local workspace_input=""
    local workspace_parent=""
    local current_path=""
    local current_downstream_root=""
    local current_context=""
    local project_roots=()
    local project_root=""
    local project_name=""

    while [[ "$#" -gt 0 ]]; do
        case "$1" in
            --workspace)
                [[ $# -ge 2 ]] || { echo "Error: --workspace requires a value."; exit 1; }
                workspace_input="$2"
                shift 2
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                echo "Error: Unknown option '$1'."
                usage
                exit 1
                ;;
        esac
    done

    workspace_parent="$(resolve_workspace_parent "$workspace_input" "$APW_COMMAND_NAME list-projects")"
    current_path="$(pwd -P)"
    resolve_invocation_context "$current_path"
    current_context="$APW_INVOCATION_CONTEXT"

    echo "APW project discovery"
    echo "Workspace parent: $workspace_parent"
    echo "APW root: $APW_ROOT"
    echo "Scan model: immediate child folders of the workspace parent"
    echo

    if [[ "$current_context" == "downstream-project-root" ]]; then
        current_downstream_root="$current_path"
        echo "Current invocation context: downstream-project-root"
        echo "Current downstream project: $current_downstream_root"
        echo
    elif [[ "$current_context" == "framework-root" ]]; then
        echo "Current invocation context: framework-root"
        echo "Current context: APW framework"
        echo
    elif [[ "$current_context" == "workspace-parent" ]]; then
        echo "Current invocation context: workspace-parent"
        echo "Current context: workspace parent folder"
        echo
    elif [[ "$current_context" == "unsupported" && -n "$workspace_input" ]]; then
        echo "Current invocation context: unsupported"
        echo "Reason: $APW_INVOCATION_REASON"
        echo "Using explicit workspace override: $workspace_parent"
        echo
    fi

    while IFS= read -r project_root; do
        [[ -n "$project_root" ]] || continue
        project_roots+=("$project_root")
    done < <(list_workspace_projects "$workspace_parent")

    if [[ "${#project_roots[@]}" -eq 0 ]]; then
        echo "No downstream APW projects were detected under this workspace parent."
        echo
        echo "Next steps:"
        echo "- Create one with: $APW_COMMAND_NAME new MyProject --profile base --stack base --target \"$workspace_parent\""
        return 0
    fi

    echo "Known downstream projects:"

    for project_root in "${project_roots[@]}"; do
        project_name="$(basename "$project_root")"

        if [[ -n "$current_downstream_root" && "$project_root" == "$current_downstream_root" ]]; then
            echo "- $project_name (current project)"
        else
            echo "- $project_name"
        fi

        echo "  Path: $project_root"
        echo "  Use it for: day-to-day project work"
    done

    echo
    echo "Switch explicitly with:"
    echo "- $APW_COMMAND_NAME switch framework"
    echo "- $APW_COMMAND_NAME switch project <name>"
    echo "- $APW_COMMAND_NAME switch parent"
}

run_switch() {
    local destination="${1:-}"
    local selector=""
    local workspace_input=""
    local workspace_parent=""
    local target_path=""
    local target_kind=""
    local open_requested=0

    if [[ -z "$destination" ]]; then
        echo "Error: switch requires a destination."
        usage
        exit 1
    fi

    shift || true

    case "$destination" in
        framework|parent)
            ;;
        project)
            selector="${1:-}"
            if [[ -z "$selector" ]]; then
                echo "Error: switch project requires a project name or path."
                exit 1
            fi
            shift || true
            ;;
        *)
            echo "Error: Unknown switch destination '$destination'."
            usage
            exit 1
            ;;
    esac

    while [[ "$#" -gt 0 ]]; do
        case "$1" in
            --workspace)
                [[ $# -ge 2 ]] || { echo "Error: --workspace requires a value."; exit 1; }
                workspace_input="$2"
                shift 2
                ;;
            --open)
                open_requested=1
                shift
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                echo "Error: Unknown option '$1'."
                usage
                exit 1
                ;;
        esac
    done

    case "$destination" in
        framework)
            target_path="$APW_ROOT"
            target_kind="framework"
            ;;
        project)
            if [[ -e "$selector" ]]; then
                workspace_parent=""
            else
                workspace_parent="$(resolve_workspace_parent "$workspace_input" "$APW_COMMAND_NAME switch project")"
            fi
            target_path="$(resolve_project_switch_target "$selector" "$workspace_parent")"
            target_kind="project"
            ;;
        parent)
            workspace_parent="$(resolve_workspace_parent "$workspace_input" "$APW_COMMAND_NAME switch parent")"
            target_path="$workspace_parent"
            target_kind="parent"
            ;;
    esac

    print_switch_summary "$target_kind" "$target_path" "$open_requested"
    maybe_open_target "$target_path" "$open_requested"
}

run_new() {
    local project_name="${1:-}"
    local profile="base"
    local stack="base"
    local target_parent=""
    local force=0
    local skip_validate=0
    local init_state=0
    local project_root=""
    local creation_context=""
    local creation_reason=""
    local current_path=""

    ensure_safe_project_name "$project_name"
    shift || true

    while [[ "$#" -gt 0 ]]; do
        case "$1" in
            --profile)
                [[ $# -ge 2 ]] || { echo "Error: --profile requires a value."; exit 1; }
                profile="$2"
                shift 2
                ;;
            --stack)
                [[ $# -ge 2 ]] || { echo "Error: --stack requires a value."; exit 1; }
                stack="$2"
                shift 2
                ;;
            --target)
                [[ $# -ge 2 ]] || { echo "Error: --target requires a value."; exit 1; }
                target_parent="$2"
                shift 2
                ;;
            --force)
                force=1
                shift
                ;;
            --skip-validate)
                skip_validate=1
                shift
                ;;
            --init-state)
                init_state=1
                shift
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                echo "Error: Unknown option '$1'."
                usage
                exit 1
                ;;
        esac
    done

    require_script "$BOOTSTRAP_SCRIPT"
    require_script "$VALIDATE_SCRIPT"
    require_script "$INIT_STATE_SCRIPT"

    current_path="$(pwd -P)"
    resolve_new_project_target_parent "$target_parent" "$current_path"
    target_parent="$NEW_PROJECT_TARGET_PARENT"
    creation_context="$NEW_PROJECT_TARGET_CONTEXT"
    creation_reason="$NEW_PROJECT_TARGET_REASON"

    mkdir -p "$target_parent"
    target_parent="$(cd "$target_parent" && pwd -P)"
    project_root="$target_parent/$project_name"

    if [[ -e "$project_root" && ! -d "$project_root" ]]; then
        echo "Error: Target path exists and is not a directory: $project_root"
        exit 1
    fi

    if [[ -d "$project_root" ]]; then
        if ! directory_is_empty "$project_root"; then
            echo "Error: Project directory already exists and is not empty: $project_root"
            echo "Use a different name, choose a different --target, or use the raw bootstrap flow for an existing repo."
            exit 1
        fi
    else
        mkdir -p "$project_root"
    fi

    echo "APW workspace-friendly project creation"
    echo "Create Project action policy: this is the same destination resolver used by chat-first APW project creation."
    echo "Project: $project_name"
    echo "Current context: $current_path"
    echo "Destination policy: $creation_context"
    echo "Resolved parent: $target_parent"
    echo "Resolved destination: $project_root"
    echo "Reason: $creation_reason"
    echo "Profile: $profile"
    echo "Stack: $stack"
    echo "Override: use --target /path/to/parent for a different location."
    echo

    if [[ $force -eq 1 ]]; then
        "$BOOTSTRAP_SCRIPT" --target "$project_root" --profile "$profile" --stack "$stack" --force
    else
        "$BOOTSTRAP_SCRIPT" --target "$project_root" --profile "$profile" --stack "$stack"
    fi

    if [[ $skip_validate -eq 0 ]]; then
        "$VALIDATE_SCRIPT" "$project_root" --profile "$profile" --stack "$stack"
    else
        echo "Skipping validation because --skip-validate was requested."
    fi

    if [[ $init_state -eq 1 ]]; then
        "$INIT_STATE_SCRIPT" --target "$project_root"
    fi

    echo
    echo "APW project ready at: $project_root"
    echo "Next steps:"
    echo "1. $(format_cd_command "$project_root")"
    echo "2. Open AGENTS.md in the new repo"

    if [[ $init_state -eq 0 ]]; then
        echo "3. Run: $INIT_STATE_SCRIPT --target \"$project_root\""
        echo "4. Start day-to-day work from the downstream project root, especially .gsd/STATE.md and .gsd/TODO.md"
    else
        echo "3. Review the generated core .gsd drafts once"
        echo "4. Start day-to-day work from the downstream project root, especially .gsd/STATE.md and .gsd/TODO.md"
    fi
}

run_upgrade_project() {
    local selector="${1:-}"
    local workspace_input=""
    local workspace_parent=""
    local profile="auto"
    local stack="base"
    local dry_run=0
    local force_managed=0
    local run_validate=0
    local target_path=""
    local upgrade_args=()

    if [[ -z "$selector" ]]; then
        echo "Error: upgrade-project requires a downstream project name or path."
        usage
        exit 1
    fi

    shift || true

    while [[ "$#" -gt 0 ]]; do
        case "$1" in
            --workspace)
                [[ $# -ge 2 ]] || { echo "Error: --workspace requires a value."; exit 1; }
                workspace_input="$2"
                shift 2
                ;;
            --profile)
                [[ $# -ge 2 ]] || { echo "Error: --profile requires a value."; exit 1; }
                profile="$2"
                shift 2
                ;;
            --stack)
                [[ $# -ge 2 ]] || { echo "Error: --stack requires a value."; exit 1; }
                stack="$2"
                shift 2
                ;;
            --dry-run|--plan)
                dry_run=1
                shift
                ;;
            --force-managed)
                force_managed=1
                shift
                ;;
            --validate)
                run_validate=1
                shift
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                echo "Error: Unknown option '$1'."
                usage
                exit 1
                ;;
        esac
    done

    require_script "$UPGRADE_PROJECT_SCRIPT"
    if [[ -e "$selector" ]]; then
        target_path="$(resolve_project_switch_target "$selector" "")"
    else
        workspace_parent="$(resolve_workspace_parent "$workspace_input" "$APW_COMMAND_NAME upgrade-project")"
        target_path="$(resolve_project_switch_target "$selector" "$workspace_parent")"
    fi

    upgrade_args=(--target "$target_path" --profile "$profile" --stack "$stack")

    if [[ $dry_run -eq 1 ]]; then
        upgrade_args+=(--dry-run)
    fi

    if [[ $force_managed -eq 1 ]]; then
        upgrade_args+=(--force-managed)
    fi

    if [[ $run_validate -eq 1 ]]; then
        upgrade_args+=(--validate)
    fi

    bash "$UPGRADE_PROJECT_SCRIPT" "${upgrade_args[@]}"
}

command="${1:-help}"

case "$command" in
    new)
        shift
        run_new "${1:-}" "${@:2}"
        ;;
    upgrade-project)
        shift
        run_upgrade_project "${1:-}" "${@:2}"
        ;;
    context)
        shift
        run_context "${1:-.}"
        ;;
    first-run)
        shift
        run_first_run "${1:-.}"
        ;;
    list-projects)
        shift
        run_list_projects "$@"
        ;;
    switch)
        shift
        run_switch "$@"
        ;;
    help|-h|--help)
        usage
        ;;
    *)
        echo "Error: Unknown command '$command'."
        usage
        exit 1
        ;;
esac
